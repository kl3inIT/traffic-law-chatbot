# ============================================================================
# Server: /home/deploy/app/traffic-law/.env
# Copy: cp .env.example .env  rồi điền giá trị thật
# NEVER commit .env lên git
# ============================================================================

# --- PostgreSQL (kết nối tới pgvector container) ---
DB_URL=jdbc:postgresql://pgvector:5432/traffic_law
DB_USERNAME=postgres
DB_PASSWORD=

# --- Spring Boot ---
SPRING_PROFILES_ACTIVE=prod

# --- OpenAI API Key ---
# Set trên server, không lưu ở đây:
#   echo 'export OPENAI_API_KEY=sk-...' >> ~/.bashrc && source ~/.bashrc
# Docker Compose tự đọc từ env của server khi không có trong .env
OPENAI_API_KEY=

# --- Next.js Frontend ---
NEXT_PUBLIC_API_URL=http://10.123.123.174:8087

# --- Images (CI/CD tự override, không cần sửa) ---
BACKEND_IMAGE=git.dth.com.vn:5050/jmix-team/research/traffic-law/core/backend:latest
FRONTEND_IMAGE=git.dth.com.vn:5050/jmix-team/research/traffic-law/core/frontend:latest
