DB_URL=jdbc:postgresql://pgvector:5432/traffic_law
DB_USERNAME=postgres
DB_PASSWORD=

SPRING_PROFILES_ACTIVE=prod

OPENAI_API_KEY=

# --- Embedding API key (cho vector store) ---
# Khác với OPENAI_API_KEY — dùng riêng cho embedding provider
EMBEDDING_API_KEY=

# --- OpenAI thật (cho các model gpt-4o, gpt-4o-mini) ---
OPENAI_BASE_URL=https://api.openai.com

# --- 9router / local AI proxy (cho models cx/gpt-5.4, cc/claude-*) ---
# Tunnel URL từ 9router hoặc Tailscale
ROUTER_BASE_URL=https://rpe4uuv.9router.com/v1
ROUTER_API_KEY=dummy

# --- Domains ---
# Frontend: https://chatbot.x2h.com.vn  (Next.js → :3333 qua Nginx Proxy Manager)
# Backend:  https://api.chatbot.x2h.com.vn (Spring Boot → :8087 qua Nginx Proxy Manager)
NEXT_PUBLIC_API_BASE_URL=https://api.chatbot.x2h.com.vn

# --- CORS (backend cho phép frontend origin) ---
# Nhiều origin ngăn cách bằng dấu phẩy, không space
CORS_ALLOWED_ORIGINS=https://chatbot.x2h.com.vn,http://localhost:3000

BACKEND_IMAGE=git.dth.com.vn:5050/jmix-team/research/traffic-law/core/backend:latest
FRONTEND_IMAGE=git.dth.com.vn:5050/jmix-team/research/traffic-law/core/frontend:latest
