<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="011-ai-parameter-set-model-columns" author="system">
        <comment>Add chat_model and evaluator_model columns to ai_parameter_set for model selection</comment>
        <addColumn tableName="ai_parameter_set">
            <column name="chat_model" type="varchar(200)">
                <constraints nullable="true"/>
            </column>
            <column name="evaluator_model" type="varchar(200)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>
