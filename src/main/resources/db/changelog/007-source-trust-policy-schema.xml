<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="007-1" author="gsd-plan">
        <comment>Create source_trust_policy table for trust tier classification metadata</comment>
        <createTable tableName="source_trust_policy">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="domain_pattern" type="VARCHAR(500)">
                <constraints nullable="true"/>
            </column>
            <column name="source_type" type="VARCHAR(50)">
                <constraints nullable="true"/>
            </column>
            <column name="trust_tier" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="created_at" type="TIMESTAMPTZ" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMPTZ" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="007-2" author="gsd-plan">
        <comment>Add trust_tier column to kb_source for denormalized tier metadata</comment>
        <addColumn tableName="kb_source">
            <column name="trust_tier" type="VARCHAR(50)" defaultValue="MANUAL_REVIEW">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>
