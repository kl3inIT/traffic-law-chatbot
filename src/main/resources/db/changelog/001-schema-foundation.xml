<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="001" author="system">

        <!-- Enable pgvector extension -->
        <sql>CREATE EXTENSION IF NOT EXISTS vector;</sql>

        <!-- kb_source: trusted knowledge source registry -->
        <createTable tableName="kb_source">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="source_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="origin_kind" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="origin_value" type="TEXT"/>
            <column name="publisher_name" type="VARCHAR(255)"/>
            <column name="language_code" type="VARCHAR(10)" defaultValue="vi"/>
            <column name="status" type="VARCHAR(50)" defaultValue="DRAFT">
                <constraints nullable="false"/>
            </column>
            <column name="trusted_state" type="VARCHAR(50)" defaultValue="UNTRUSTED">
                <constraints nullable="false"/>
            </column>
            <column name="approval_state" type="VARCHAR(50)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="active_version_id" type="UUID"/>
            <column name="created_at" type="TIMESTAMPTZ" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="VARCHAR(255)"/>
            <column name="updated_at" type="TIMESTAMPTZ" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_by" type="VARCHAR(255)"/>
        </createTable>

        <!-- kb_source_version: versioned ingestion snapshot per source -->
        <createTable tableName="kb_source_version">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="source_id" type="UUID">
                <constraints nullable="false" foreignKeyName="fk_ksv_source" references="kb_source(id)"/>
            </column>
            <column name="version_no" type="INTEGER" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <column name="content_hash" type="VARCHAR(64)"/>
            <column name="ingest_method" type="VARCHAR(50)"/>
            <column name="mime_type" type="VARCHAR(100)"/>
            <column name="file_name" type="VARCHAR(500)"/>
            <column name="storage_uri" type="TEXT"/>
            <column name="canonical_url" type="TEXT"/>
            <column name="fetched_at" type="TIMESTAMPTZ"/>
            <column name="parser_name" type="VARCHAR(100)"/>
            <column name="parser_version" type="VARCHAR(50)"/>
            <column name="chunking_strategy" type="VARCHAR(100)"/>
            <column name="chunking_version" type="VARCHAR(50)"/>
            <column name="processing_version" type="VARCHAR(50)"/>
            <column name="index_status" type="VARCHAR(50)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="summary_json" type="JSONB"/>
            <column name="created_at" type="TIMESTAMPTZ" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- kb_ingestion_job: async ingestion job tracking -->
        <createTable tableName="kb_ingestion_job">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="source_id" type="UUID">
                <constraints nullable="false" foreignKeyName="fk_kij_source" references="kb_source(id)"/>
            </column>
            <column name="source_version_id" type="UUID">
                <constraints foreignKeyName="fk_kij_source_version" references="kb_source_version(id)"/>
            </column>
            <column name="job_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(50)" defaultValue="QUEUED">
                <constraints nullable="false"/>
            </column>
            <column name="queued_at" type="TIMESTAMPTZ" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="started_at" type="TIMESTAMPTZ"/>
            <column name="finished_at" type="TIMESTAMPTZ"/>
            <column name="retry_count" type="INTEGER" defaultValueNumeric="0"/>
            <column name="triggered_by" type="VARCHAR(255)"/>
            <column name="trigger_type" type="VARCHAR(50)"/>
            <column name="error_code" type="VARCHAR(100)"/>
            <column name="error_message" type="TEXT"/>
            <column name="step_name" type="VARCHAR(50)"/>
            <column name="step_detail_json" type="JSONB"/>
        </createTable>

        <!-- kb_source_approval_event: approval audit trail -->
        <createTable tableName="kb_source_approval_event">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="source_id" type="UUID">
                <constraints nullable="false" foreignKeyName="fk_ksae_source" references="kb_source(id)"/>
            </column>
            <column name="source_version_id" type="UUID">
                <constraints foreignKeyName="fk_ksae_source_version" references="kb_source_version(id)"/>
            </column>
            <column name="action" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="previous_state" type="VARCHAR(50)"/>
            <column name="new_state" type="VARCHAR(50)"/>
            <column name="reason" type="TEXT"/>
            <column name="acted_by" type="VARCHAR(255)"/>
            <column name="acted_at" type="TIMESTAMPTZ" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- kb_source_fetch_snapshot: HTTP fetch provenance per version -->
        <createTable tableName="kb_source_fetch_snapshot">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="source_version_id" type="UUID">
                <constraints nullable="false" foreignKeyName="fk_ksfs_source_version" references="kb_source_version(id)"/>
            </column>
            <column name="requested_url" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="final_url" type="TEXT"/>
            <column name="http_status" type="INTEGER"/>
            <column name="etag" type="VARCHAR(255)"/>
            <column name="last_modified" type="TIMESTAMPTZ"/>
            <column name="content_sha256" type="VARCHAR(64)"/>
            <column name="fetched_at" type="TIMESTAMPTZ" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Indexes -->
        <createIndex indexName="idx_kb_source_status_approval_trust" tableName="kb_source">
            <column name="status"/>
            <column name="approval_state"/>
            <column name="trusted_state"/>
        </createIndex>

        <createIndex indexName="idx_kb_ingestion_job_source_status" tableName="kb_ingestion_job">
            <column name="source_id"/>
            <column name="status"/>
        </createIndex>

        <createIndex indexName="idx_kb_source_version_source" tableName="kb_source_version">
            <column name="source_id"/>
        </createIndex>

    </changeSet>

</databaseChangeLog>
