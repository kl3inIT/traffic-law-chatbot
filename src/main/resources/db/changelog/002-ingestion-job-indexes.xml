<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="002" author="system">

        <!-- Composite index for queued-job polling: status + queue order -->
        <createIndex indexName="idx_ingestion_job_status_queued" tableName="kb_ingestion_job">
            <column name="status"/>
            <column name="queued_at"/>
        </createIndex>

        <!-- Index for fetch snapshot lookups by version -->
        <createIndex indexName="idx_source_fetch_snapshot_version" tableName="kb_source_fetch_snapshot">
            <column name="source_version_id"/>
        </createIndex>

    </changeSet>

</databaseChangeLog>
